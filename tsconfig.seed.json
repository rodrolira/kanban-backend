{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "lib": ["ES2020"],
      "moduleResolution": "node",
      "esModuleInterop": true,
      "allowJs": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "strict": true,
      "noImplicitAny": false,
      "types": ["node"]
    },
    "ts-node": {
      "transpileOnly": true,
      "compilerOptions": {
        "module": "commonjs"
      }
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules"]
  }